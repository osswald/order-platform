# Loaded by docker compose from /opt/vendiqo/pi/.env on the Pi.
PI_BACKEND_IMAGE=ghcr.io/osswald/order-platform:pi-backend-latest
PI_FRONTEND_IMAGE=ghcr.io/osswald/order-platform:pi-frontend-latest
# Host path bind-mounted to /ota-state in pi-backend (freeze + blacklist for OTA).
OTA_STATE_HOST_DIR=/opt/vendiqo/pi/ota-state
# OTA_MIN_FREE_BYTES=2147483648
# FORCE_UPDATE=0
