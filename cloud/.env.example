# PostgreSQL
POSTGRES_USER=cloud
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cloud
# Optional: bind mount on the VPS, e.g. POSTGRES_DATA_PATH=/data/postgres
# POSTGRES_DATA_PATH=/data/postgres

# Backend
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=https://admin.vendiqo.ch
REFRESH_COOKIE_SECURE=true
ENABLE_OPENAPI=false
LOGIN_RATE_LIMIT=10/minute

# Stripe Connect / Terminal (prefer a restricted key with Connect, PaymentIntent, and Terminal permissions)
STRIPE_SECRET_KEY=rk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_RETURN_URL=https://admin.vendiqo.ch/settings/stripe/return
STRIPE_CONNECT_REFRESH_URL=https://admin.vendiqo.ch/settings/stripe/refresh

# Bootstrap first superuser (optional; only created if no user with this email exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Frontend build (baked into the static image at build time)
VITE_API_BASE_URL=https://api.vendiqo.ch
