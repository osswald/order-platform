# Copy to `.env` and adjust. `docker compose` loads `pi/.env` automatically.

# Cloud API base (no trailing slash). For Pi backend in Docker talking to cloud on the host:
#   http://host.docker.internal:8000
# Production:
#   https://api.yourdomain.com
CLOUD_BASE_URL=http://host.docker.internal:8000

# Setup pairing cloud base URL.
# DEFAULT_CLOUD_BASE_URL=https://api.vendiqo.ch
# PI_SETUP_UNPAIR_SECRET=  # production: long random secret for POST /v1/setup/unpair

# Optional; default is fine for compose volume.
# DATABASE_URL=sqlite:////data/pi.db

# Background Pi ↔ cloud sync (push outbox, pull bundle). Requires successful pairing.
# SYNC_ENABLED=1
# SYNC_INTERVAL_SECONDS=60
# SYNC_PUSH_ENABLED=0   # hosted Cloud-Pi sandboxes: pull only
# RESTORE_FROM_CLOUD=1  # auto-restore open ops from cloud after bundle pull (default on)

# Hosted Cloud-Pi (set by orchestrator on cloud VPS):
# HOSTED_PI=1
# PRINTER_MODE=emulated
# EDGE_CLIENT_ID=
# EDGE_SECRET=

# Pi PWA (browser) → Pi API. Default matches compose port mapping 8001:8000.
# VITE_API_BASE=http://localhost:8001

# Optional: redirect all TCP print jobs to one host (e.g. 192.168.1.50). Leave unset to use
# printer IPs from the synced cloud bundle.
# ESCPOS_PRINTER_HOST_OVERRIDE=192.168.1.50
# ESC/POS charset (default PC858 / code page 19 for äöü éèç):
# ESCPOS_ENCODING=cp858
# ESCPOS_CODEPAGE=19
# ESCPOS_LINE_WIDTH=48   # network/kitchen slips; Bluetooth uses 80/58/53 mm in app settings
# ESCPOS_TIMEZONE=Europe/Zurich
# ESCPOS_HERO_SCALE=8
# ESCPOS_LOGO_MAX_WIDTH=384
