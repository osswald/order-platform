{
  "name": "cloud-frontend",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "generate:api-types": "openapi-typescript ./openapi.json -o ./src/types/api.generated.ts",
    "lint": "eslint --config ../../eslint.config.js src"
  },
  "dependencies": {
    "@date-io/date-fns": "^3.2.1",
    "@mdi/font": "^7.4.47",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "markdown-it": "^14.2.0",
    "openapi-fetch": "^0.14.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.6.4",
    "vuetify": "^3.7.5"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.10.6",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.3",
    "vite-plugin-vuetify": "^2.0.4",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
