# Compose loads this file as env_file (same syntax as .env).
# To use another image, change BASE_IMG_URL (see Raspberry Pi OS downloads).

# Direct HTTPS URL to Raspberry Pi OS Lite arm64 (.img.xz or .img).
BASE_IMG_URL=https://downloads.raspberrypi.com/raspios_lite_arm64/images/raspios_lite_arm64-2026-04-21/2026-04-21-raspios-trixie-arm64-lite.img.xz

# First-boot Raspberry Pi OS settings applied by SDM.
PI_LOCALE=en_GB.UTF-8
PI_KEYMAP=ch
PI_TIMEZONE=Europe/Zurich
PI_WIFI_COUNTRY=CH
PI_USERNAME=vendiqo-user

# Copy this file to .env and set exactly one password option before building.
# PI_PASSWORD=
# PI_PASSWORD_HASH=
