# Copy to `.env` and adjust. `docker compose` loads `pi/.env` automatically.

# Cloud API base (no trailing slash). For Pi backend in Docker talking to cloud on the host:
#   http://host.docker.internal:8000
# Production:
#   https://api.yourdomain.com
CLOUD_BASE_URL=http://host.docker.internal:8000

# Create a **server** appliance in cloud admin, then paste the edge id and secret shown once (must be non-empty).
EDGE_CLIENT_ID=
EDGE_SECRET=

# Optional; default is fine for compose volume.
# DATABASE_URL=sqlite:////data/pi.db

# Background Pi ↔ cloud sync (push outbox, pull bundle). Requires EDGE_* and CLOUD_BASE_URL.
# SYNC_ENABLED=1
# SYNC_INTERVAL_SECONDS=60

# Pi PWA (browser) → Pi API. Default matches compose port mapping 8001:8000.
# VITE_API_BASE=http://localhost:8001

# Optional: override print target (compose default escpos-netprinter for local emulator).
# Local emulator (default for docker compose dev). Comment out for a real LAN printer.
ESCPOS_PRINTER_HOST_OVERRIDE=escpos-netprinter
# Receipts UI: http://localhost:8090
# ESC/POS charset (default PC858 / code page 19 for äöü éèç):
# ESCPOS_ENCODING=cp858
# ESCPOS_CODEPAGE=19
# ESCPOS_LINE_WIDTH=48
# ESCPOS_TIMEZONE=Europe/Zurich
# ESCPOS_HERO_SCALE=8
