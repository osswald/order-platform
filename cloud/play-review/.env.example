# Copy to `.env` on the VPS (never commit secrets).

PI_BACKEND_IMAGE=ghcr.io/osswald/order-platform:pi-backend-amd64-latest
PI_FRONTEND_IMAGE=ghcr.io/osswald/order-platform:pi-frontend-amd64-latest

CLOUD_BASE_URL=https://api.vendiqo.ch
EDGE_CLIENT_ID=
EDGE_SECRET=

# Docker network shared with production Caddy (cloud docker-compose.prod.yml)
CADDY_NETWORK=cloud_app-net

# Public URL used by deploy script health checks
PLAY_REVIEW_URL=https://play-review.demo.vendiqo.ch

# Shared secret for POST /v1/ops/purge-operational (nightly cleanup)
PLAY_REVIEW_CLEANUP_SECRET=

# Optional: also purge cloud operational data for this event (admin bearer token)
PLAY_REVIEW_EVENT_ID=
PLAY_REVIEW_CLOUD_TOKEN=
PLAY_REVIEW_CLOUD_API_BASE=https://api.vendiqo.ch
